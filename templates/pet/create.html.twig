{% extends 'base.html.twig' %}

{% block title %}Dodaj zwierzaka{% endblock %}

{% block body %}
    <h1>Dodaj zwierzaka</h1>

    {{ form_start(form, { attr: { enctype: 'multipart/form-data' } }) }}
        {{ form_row(form.id) }}
        {{ form_row(form.name) }}
        {{ form_row(form.status) }}
        {{ form_row(form.categoryId) }}
        {{ form_row(form.categoryName) }}
        {{ form_row(form.tagsInput) }}

        <h2>Zdjęcia</h2>
        <p>Możesz wybrać jeden lub wiele plików obrazu do przesłania po zapisaniu zwierzaka.</p>
        {{ form_row(form.imageUpload.additionalMetadata) }}
        {{ form_row(form.imageUpload.images) }}

        {{ form_row(form.save) }}
    {{ form_end(form) }}

    <p>
        <a href="{{ path('pet_index') }}">Powrót do strony głównej</a>
    </p>
{% endblock %}