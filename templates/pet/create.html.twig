{% extends 'base.html.twig' %}

{% block title %}Dodaj zwierzaka{% endblock %}

{% block body %}
    <h1>Dodaj zwierzaka</h1>

    {{ form_start(form) }}
        {{ form_row(form.id) }}
        {{ form_row(form.name) }}
        {{ form_row(form.status) }}
        {{ form_row(form.categoryId) }}
        {{ form_row(form.categoryName) }}
        {{ form_row(form.tagsInput) }}
        {{ form_row(form.photoUrlsInput) }}
        {{ form_row(form.save) }}
    {{ form_end(form) }}

    <p>
        <a href="{{ path('pet_index') }}">Powrót do strony głównej</a>
    </p>
{% endblock %}