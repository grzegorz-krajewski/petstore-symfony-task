{% extends 'base.html.twig' %}

{% block title %}Edytuj zwierzaka{% endblock %}

{% block body %}
    <h1>Edytuj zwierzaka</h1>

    <p>Zarządzanie zdjęciami jest dostępne na ekranie szczegółów zwierzaka.</p>

    {{ form_start(form) }}
        {{ form_row(form.id) }}
        {{ form_row(form.name) }}
        {{ form_row(form.status) }}
        {{ form_row(form.categoryId) }}
        {{ form_row(form.categoryName) }}
        {{ form_row(form.tagsInput) }}
        {{ form_row(form.save) }}
    {{ form_end(form) }}

    <p>
        <a href="{{ path('pet_show', { id: petId }) }}">Powrót do szczegółów</a>
    </p>
{% endblock %}