{% extends 'base.html.twig' %}

{% block title %}Szczegóły {% endblock %}

{% block body %}
    <h1>Szczegóły</h1>

    <p><strong>ID:</strong> {{ pet.id ?? 'brak danych' }}</p>
    <p><strong>Nazwa:</strong> {{ pet.name ?? 'brak danych' }}</p>
    <p><strong>Status:</strong> {{ pet.status ?? 'brak danych' }}</p>

    <p>
        <a href="{{ path('pet_edit', { id: pet.id }) }}">Edytuj</a>
    </p>

    <form method="post" action="{{ path('pet_delete', { id: pet.id }) }}">
        <button type="submit">Usuń</button>
    </form>

    <p>
        <a href="{{ path('pet_index') }}">Powrót do strony głównej</a>
    </p>
{% endblock %}